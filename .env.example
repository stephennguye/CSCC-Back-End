# ============================================================
# AI Call Center Backend — Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# ----------------------------
# Database (PostgreSQL)
# ----------------------------
DATABASE_URL=postgresql+asyncpg://cscc:cscc_pass@localhost:5432/cscc_db

# AES-256 key for pgcrypto PII field encryption (32-byte hex string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PGCRYPTO_KEY=<32-byte-hex-key>

# ----------------------------
# Redis
# ----------------------------
REDIS_URL=redis://localhost:6379/0

# ----------------------------
# LLM — Primary (OpenAI)
# ----------------------------
OPENAI_API_KEY=sk-...

# ----------------------------
# LLM — Fallback (HuggingFace)
# ----------------------------
HUGGINGFACE_API_TOKEN=hf_...
HUGGINGFACE_FALLBACK_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ----------------------------
# Speech-to-Text (STT)
# ----------------------------
# Options: tiny, base, medium, large-v3
FASTER_WHISPER_MODEL=large-v3

# Minimum ASR confidence before emitting transcript.low_confidence frame
ASR_CONFIDENCE_THRESHOLD=0.70

# ----------------------------
# Text-to-Speech (TTS)
# ----------------------------
# Primary TTS engine: coqui | edge_tts
TTS_PRIMARY=coqui

# Coqui TTS model identifier
TTS_COQUI_MODEL=tts_models/en/ljspeech/vits

# ----------------------------
# Embeddings / Vector Store
# ----------------------------
EMBEDDING_MODEL=BAAI/bge-m3
CHROMA_DB_PATH=./data/chroma

# ----------------------------
# Observability
# ----------------------------
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090

# ----------------------------
# Security / JWT
# ----------------------------
# HS256 secret for signing session JWTs (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=<replace-with-strong-secret>

# JWT token TTL in seconds
SESSION_TOKEN_TTL_SECONDS=300

# ----------------------------
# CORS
# ----------------------------
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# ----------------------------
# Debug (MUST NOT be true in production)
# ----------------------------
# Set to true only for local debugging of LLM prompt inputs
LLM_DEBUG_LOG_PROMPTS=false
